# ============================================================
# WordPress Multitenancy Platform - Environment Configuration
# ============================================================
# Copy this file to .env and change all passwords!
#   cp .env.example .env
# NEVER commit .env to version control.
# ============================================================

# ---- Tenant Alpha ----
ALPHA_DB_ROOT_PASSWORD=alpha_root_change_me
ALPHA_DB_NAME=wp_alpha
ALPHA_DB_USER=wp_alpha_user
ALPHA_DB_PASSWORD=alpha_db_change_me
ALPHA_DOMAIN=tenant-alpha.localhost
ALPHA_WP_DEBUG=false

# ---- Tenant Beta ----
BETA_DB_ROOT_PASSWORD=beta_root_change_me
BETA_DB_NAME=wp_beta
BETA_DB_USER=wp_beta_user
BETA_DB_PASSWORD=beta_db_change_me
BETA_DOMAIN=tenant-beta.localhost
BETA_WP_DEBUG=false

# ---- Nginx ----
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ---- Grafana ----
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=grafana_change_me
GRAFANA_PORT=3000

# ---- Prometheus ----
PROMETHEUS_PORT=9090

# ---- General ----
COMPOSE_PROJECT_NAME=wp-multitenant
